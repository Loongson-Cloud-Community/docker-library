# This file is generated by the template.

REGISTRY        ?= lcr.loongnix.cn
ORGANIZATION    ?= qmcgaw
REPOSITORY      ?= binpot
TAG             ?= master
LATEST          ?= false

IMAGE=$(REGISTRY)/$(ORGANIZATION)/$(REPOSITORY)
LATEST_IMAGE=$(REGISTRY)/$(ORGANIZATION)/$(REPOSITORY):latest
SOURCE=binpot
SOURCE_URL=https://github.com/qdm12/binpot.git
PATCH=0001-Add-loongarch-support.patch

# 代理参数（从外部接收，支持环境变量）
HTTP_PROXY ?= $(shell echo $$HTTP_PROXY)
HTTPS_PROXY ?= $(shell echo $$HTTPS_PROXY)

# 需要跳过的子目录
SKIP_DIRS := gitstatus

# CI 默认调用的规则
.PHONY: image
image: 
	@echo "Starting build process..."
	@echo "HTTP_PROXY: $(HTTP_PROXY)"
	@echo "HTTPS_PROXY: $(HTTPS_PROXY)"
	@$(MAKE) all

# 克隆源码
src/$(SOURCE):
	git clone --depth=1 $(SOURCE_URL) $@
	cd $@ && git apply ../../$(PATCH)

# 构建所有镜像
.PHONY: all
all: src/$(SOURCE)
	@cd src/$(SOURCE)/dockerfiles && \
	echo "Building images in: $$PWD"; \
	for dir in */; do \
		dir=$${dir%/}; \
		if echo "$(SKIP_DIRS)" | grep -q "$$dir"; then \
			echo "Skipping $$dir..."; \
			continue; \
		fi; \
		if [ ! -f "$$dir/Dockerfile" ]; then \
			echo "Warning: $$dir/Dockerfile not found, skipping..."; \
			continue; \
		fi; \
		echo "Building $$dir..."; \
		VERSION=$$(grep -E "^ARG VERSION=" $$dir/Dockerfile | cut -d'=' -f2); \
		if [ -z "$$VERSION" ]; then \
			echo "Error: VERSION not found in $$dir/Dockerfile"; \
			exit 1; \
		fi; \
		docker build --build-arg HTTP_PROXY=$(HTTP_PROXY) --build-arg HTTPS_PROXY=$(HTTPS_PROXY) -t $(IMAGE):$$dir-$$VERSION $$dir; \
		echo "✓ Built $(IMAGE):$$dir-$$VERSION"; \
	done

# 构建单个镜像
.PHONY: build-%
build-%: src/$(SOURCE)
	@dir=$*; \
	cd src/$(SOURCE)/dockerfiles/$$dir && \
	VERSION=$$(grep -E "^ARG VERSION=" Dockerfile | cut -d'=' -f2); \
	docker build --build-arg HTTP_PROXY=$(HTTP_PROXY) --build-arg HTTPS_PROXY=$(HTTPS_PROXY) -t $(IMAGE):$$dir-$$VERSION .

# 推送所有镜像
.PHONY: push
push: src/$(SOURCE)
	@cd src/$(SOURCE)/dockerfiles && \
	for dir in */; do \
		dir=$${dir%/}; \
		if echo "$(SKIP_DIRS)" | grep -q "$$dir"; then \
			continue; \
		fi; \
		VERSION=$$(grep -E "^ARG VERSION=" $$dir/Dockerfile | cut -d'=' -f2); \
		docker push $(IMAGE):$$dir-$$VERSION; \
	done
	@if [ $(LATEST) = "true" ]; then \
		docker tag $(IMAGE) $(LATEST_IMAGE); \
		docker push $(LATEST_IMAGE); \
	fi

# 列出所有可用的镜像
.PHONY: list
list: src/$(SOURCE)
	@cd src/$(SOURCE)/dockerfiles && \
	echo "Available images:"; \
	for dir in */; do \
		dir=$${dir%/}; \
		VERSION=$$(grep -E "^ARG VERSION=" $$dir/Dockerfile | cut -d'=' -f2); \
		if echo "$(SKIP_DIRS)" | grep -q "$$dir"; then \
			echo "  $$dir (skipped)"; \
		else \
			echo "  $(IMAGE):$$dir-$$VERSION"; \
		fi; \
	done

# 清理
.PHONY: clean
clean:
	rm -rf src

# 默认规则
.PHONY: default
default: image

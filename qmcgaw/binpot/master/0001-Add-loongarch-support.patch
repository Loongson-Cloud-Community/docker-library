diff --git a/dockerfiles/bit/Dockerfile b/dockerfiles/bit/Dockerfile
index 0642f8b..8bd9ae2 100644
--- a/dockerfiles/bit/Dockerfile
+++ b/dockerfiles/bit/Dockerfile
@@ -1,11 +1,11 @@
-ARG ALPINE_VERSION=3.23
+ARG ALPINE_VERSION=3.22
 ARG GO_VERSION=1.26
 ARG XCPU_VERSION=v0.9.0
-ARG BUILDPLATFORM=linux/amd64
+ARG BUILDPLATFORM=linux/loong64
 
-FROM --platform=${BUILDPLATFORM} ghcr.io/qdm12/xcputranslate:${XCPU_VERSION} AS xcputranslate
+FROM --platform=${BUILDPLATFORM} lcr.loongnix.cn/qdm12/xcputranslate:${XCPU_VERSION} AS xcputranslate
 
